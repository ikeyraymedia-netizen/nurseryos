# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for QuickBooks OAuth return links.
APP_URL="https://nurseryos.app"

# SMTP Email Configuration (Nodemailer)
# If configured, invoices can be sent directly from the server.
# Otherwise, the app gracefully falls back to client-side mailto links.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SENDER_EMAIL=

# QuickBooks Online (Intuit Developer app)
# Use Development keys + sandbox until go-live.
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=https://nurseryos.app/api/quickbooks/callback
# sandbox | production
QUICKBOOKS_ENVIRONMENT=sandbox

# Stripe Connect (platform account)
# Use test keys (sk_test_… / pk_test_…) until go-live.
# Enable Connect in the Stripe Dashboard, then add a webhook endpoint:
#   https://nurseryos.app/api/stripe/webhook
# Events: checkout.session.completed, account.updated
# IMPORTANT: set “Listen to events on Connected accounts” (Events from → Connected accounts).
# Direct-charge payments appear under Connect → Accounts → [nursery], not platform Payments.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Firebase Admin (server) — required for QuickBooks token storage / push
# Railway tip: do NOT paste raw JSON (newlines break it). Use base64 instead:
#   base64 -i ~/Downloads/your-service-account.json | pbcopy
# Then set FIREBASE_SERVICE_ACCOUNT_BASE64 to the clipboard (no quotes).
FIREBASE_SERVICE_ACCOUNT_BASE64=
# Optional fallback (often breaks on Railway):
# FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=nurseryos-54c15
FIRESTORE_DATABASE_ID=(default)
